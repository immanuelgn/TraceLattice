NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enables Enhanced scan, which renders public pages with Cloudflare Browser Rendering.
# Standard scan works without these values.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional override if Cloudflare changes the REST path or you proxy the render endpoint.
# {accountId} is replaced with CLOUDFLARE_ACCOUNT_ID when present.
CLOUDFLARE_BROWSER_RENDER_ENDPOINT=

# Optional persistent lifetime scan counter. Vercel Marketplace injects these automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
